#include <iostream>
using namespace std;
int main()
{
    int a[100],zero=0,one=0,l;
    cin>>l;
    for(int i=0;i<l;i++){
        cin>>a[i];
        if(a[i]==0){
            zero++;
        }
        else
            one++;
    }
    for(int i=0;i<l;i++){
        if(i<zero)
            a[i]=0;
        else
            a[i]=1;
    }
    for(int i=0;i<l;i++){
        cout<<a[i]<<" ";
    }
    return 0;
}
