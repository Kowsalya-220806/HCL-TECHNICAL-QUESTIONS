import java.util.*;
public class Main
{
    public static int sumdigits(int n){
        int sum=0;
        while(n!=0){
		    int d=n%10;
		    n=n/10;
		    sum=sum+d;
	    }
	    if(sum>=0&&sum<10){
		    return sum;
        }else{
            return sumdigits(sum);
        }
    }
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
		int res=sumdigits(n);
		System.out.println(res);
	}
}
